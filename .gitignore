# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Django stuff:
*.log
db.sqlite3
db.sqlite3-journal
/media/
*.pot
*.pyc

# If you're using the .env file to store environment variables
.env

# Local development
*.local

# pyenv
.python-version

# Node.js related (if applicable, like with Next.js frontend in the same project)
node_modules/
npm-debug.log
yarn-debug.log
yarn-error.log

# Static files
/staticfiles/
/static/

# Media files
/media/

# VS Code files
.vscode/

# Coverage reports
htmlcov/
.coverage
*.cover
.hypothesis/

# Testing results
.tox/
.pytest_cache/

# MacOS files
.DS_Store
